# Copy to .env.local and fill in values.
# The app works immediately with zero config using built-in mock responses.

# OpenRouter — free LLMs (https://openrouter.ai/keys)
OPENROUTER_API_KEY=Enter your OpenRouter API key here (sk-...)
# Server port (optional, defaults to 5000)
PORT=5000
GROQ_API_KEY=Enter your Groq API key here (gsk-...)